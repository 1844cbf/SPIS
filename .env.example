# Runtime
APP_NAME=spis-agent-platform
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Lightweight mode for Tencent CVM 4c/4G.
WORKER_CONCURRENCY=1
TASK_DB_PATH=/data/spis_tasks.sqlite3

# Shared secret used by Hermes or other gateways when calling this service.
ORCHESTRATOR_SHARED_SECRET=

# OpenAI-compatible review provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5

# DeepSeek: coding / repair.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Doubao / Volcengine Ark: Chinese business rules / docs.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=

# GitHub is the source of truth.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GIT_DEFAULT_BRANCH=main

# Feishu outbound callback is optional for v1.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DEFAULT_CHAT_ID=
